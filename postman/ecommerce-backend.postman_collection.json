{
  "info": {
    "name": "E-Commerce Backend",
    "_postman_id": "8fb7d53f-9e6c-4f04-8e72-8d61d953b8a9",
    "description": "Sample collection for the Spring Boot e-commerce backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "orderId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "addressId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Aman\",\n  \"lastName\": \"Kumar\",\n  \"email\": \"aman@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Password@123\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"aman@example.com\",\n  \"password\": \"Password@123\"\n}"
        }
      }
    },
    {
      "name": "Category - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/categories",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Phones, laptops and accessories\"\n}"
        }
      }
    },
    {
      "name": "Product - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"name\": \"iPhone 16\",\n  \"description\": \"Flagship smartphone\",\n  \"imageUrl\": \"https://cdn.example.com/iphone16.png\",\n  \"price\": 99999,\n  \"stockQuantity\": 25,\n  \"active\": true\n}"
        }
      }
    },
    {
      "name": "Products - Search",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/products?search=phone&page=0&size=10&sortBy=price&sortDir=asc"
      }
    },
    {
      "name": "User - Add Address",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/users/me/addresses",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"label\": \"Home\",\n  \"line1\": \"221B Baker Street\",\n  \"line2\": \"Near City Center\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"country\": \"India\",\n  \"postalCode\": \"560001\",\n  \"isDefault\": true\n}"
        }
      }
    },
    {
      "name": "Cart - Add Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/cart/items",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
        }
      }
    },
    {
      "name": "Order - Checkout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/orders/checkout",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"addressId\": {{addressId}},\n  \"shippingFee\": 99\n}"
        }
      }
    },
    {
      "name": "Payment - Pay Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/payments/orders/{{orderId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider\": \"MOCK\",\n  \"idempotencyKey\": \"pay-order-001\"\n}"
        }
      }
    },
    {
      "name": "Admin - Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/admin/dashboard"
      }
    }
  ]
}
